# --- runtime state (regenerated by herdr, never committed) ---
# ~/.config/herdr stays a real directory on the machine; home-manager links
# only config.toml. These patterns guard against an accidental whole-directory
# copy into the repo.

# logs
*.log

# session/workspace state
session.json

# cached release notes
release-notes.json

# plugin registry (generated; has machine paths + timestamps)
plugins.json
.plugins.lock

# installed plugins (git clones / build artifacts)
plugins/
