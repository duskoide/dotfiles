{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "zenmux": {
      "options": {
        "apiKey": "{env:ZENMUX_API_KEY}"
      },
      "models": {
        "z-ai/glm-5.2-free": {
          "name": "GLM 5.2 free"
        },
        "moonshotai/kimi-k2.7-code-free": {
          "name": "Kimi K2.7 Code free"              
        }
      }
    },
    "poolside": {
      "api": "openai",
      "options": {
        "apiKey": "{env:POOLSIDE_API_KEY}",
        "baseURL": "https://inference.poolside.ai/v1"
      },
      "models": {
        "laguna-m.1": {
          "name": "Laguna M.1"
        },
        "laguna-xs.2": {
          "name": "Laguna XS.2"
        }
      }
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    },
    "typeui": {
      "type": "remote",
      "url": "https://mcp.typeui.sh",
      "enabled": true
    }
  },
  

  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git",
    "@dietrichgebert/ponytail"
  ]
}
