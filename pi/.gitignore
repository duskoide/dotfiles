# --- runtime state (regenerated by pi, never committed) ---
# ~/.pi/agent stays a real directory on the machine; home-manager links only
# the static config files below into it. These patterns guard against an
# accidental whole-directory copy into the repo.

# secrets — provider credentials, re-auth on each machine instead
auth.json

# caches / regenerated stores
*.cache.json
models-store.json

# session history + memory/daily logs
agent/sessions/
agent/memory/
agent/npm/
agent/output/
output/

# stray runtime artifacts (e.g. turso sqld data dir, probe files)
agent/agents/data.sqld/
agent/agents/.test-probe*

# python venvs from extensions
**/.venv/
.ready
.gcc_lib_path
